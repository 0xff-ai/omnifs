{
  "provider": {
    "id": "<PROVIDER_ID>",
    "meta": {
      "name": "dns",
      "version": "0.2.1"
    }
  },
  "mount": "dns",
  "capabilities": {
    "domains": [
      "cloudflare-dns.com",
      "dns.google"
    ],
    "git_repos": null,
    "unix_sockets": null,
    "preopened_paths": null
  },
  "limits": {
    "max_memory_mb": 32
  },
  "config": {
    "default_resolver": "cloudflare"
  }
}
