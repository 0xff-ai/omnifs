{
  "id": "static-auth",
  "displayName": "Static Auth",
  "provider": "static_auth_provider.wasm",
  "defaultMount": "static-auth",
  "auth": {
    "inject": {
      "domains": ["api.github.com"],
      "header": "Authorization",
      "prefix": "Bearer "
    },
    "default": "github",
    "schemes": {
      "github": {
        "type": "staticToken",
        "description": "GitHub personal access token"
      }
    }
  }
}
