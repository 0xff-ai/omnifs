{
  "id": "oauth-loopback",
  "displayName": "OAuth Loopback",
  "provider": "oauth_loopback_provider.wasm",
  "defaultMount": "oauth-loopback",
  "auth": {
    "inject": {
      "domains": ["api.linear.app"],
      "header": "Authorization",
      "prefix": "Bearer "
    },
    "default": "linear",
    "schemes": {
      "linear": {
        "type": "oauth",
        "displayName": "Linear",
        "clientId": "linear-client",
        "scopes": ["read"],
        "flow": {
          "kind": "pkceLoopback",
          "authorizationEndpoint": "https://linear.app/oauth/authorize",
          "tokenEndpoint": "https://api.linear.app/oauth/token",
          "redirectUriTemplate": "http://127.0.0.1:{port}/callback"
        }
      }
    }
  }
}
