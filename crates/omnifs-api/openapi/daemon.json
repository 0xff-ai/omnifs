{
  "openapi": "3.1.0",
  "info": {
    "title": "omnifs daemon control API",
    "description": "omnifs runtime daemon: provider registry and namespace server",
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "7.0"
  },
  "paths": {
    "/v1/credentials": {
      "get": {
        "operationId": "credentials_list",
        "responses": {
          "200": {
            "description": "registered credential health",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CredentialStatus"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/credentials/{id}/reload": {
      "post": {
        "operationId": "credential_reload",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "credential storage key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "refreshed credential health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialStatus"
                }
              }
            }
          },
          "400": {
            "description": "invalid credential id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "credential not registered with the daemon",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/events": {
      "get": {
        "summary": "Stream the inspector history snapshot followed by live records as\nnewline-framed JSON using the same wire format the raw TCP listener used to\nspeak, now chunk-encoded by HTTP. A lagged subscriber gets a\n`# dropped N events` comment line and resumes from the newest record.",
        "operationId": "events",
        "responses": {
          "200": {
            "description": "newline-framed inspector event stream",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "inspector stream disabled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/frontend/attach-target": {
      "post": {
        "summary": "`POST /v1/frontend/attach-target`: bind the TCP namespace attach listener on a\nrunning daemon, so a containerized frontend (the Docker Desktop path, which\ncannot share a host Unix socket into its Linux VM) can be started later\nwithout restarting the daemon. Docker Desktop uses loopback; native Linux\nasks for the Docker bridge gateway so the container can cross network\nnamespaces without exposing the listener on every host interface.\nIdempotent: a repeat call returns the already-bound address and token\nunchanged, since a listener cannot be re-pointed once serving.",
        "operationId": "frontend_attach_target",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/FrontendAttachTargetRequest"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "the TCP attach listener's address and per-instance token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FrontendAttachTargetReport"
                }
              }
            }
          },
          "400": {
            "description": "the requested address is not an approved attach boundary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "failed to bind the attach listener",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "503": {
            "description": "the namespace is not ready yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/frontend/attach-target/vsock": {
      "post": {
        "summary": "`POST /v1/frontend/attach-target/vsock`: bind the token-checking UDS namespace\nattach listener on a running daemon, for the krunkit vsock-proxy path (a\nmacOS guest VM with no shared host Unix socket and no Docker-style loopback\neither; it dials host vsock instead, and krunkit proxies every connection\nonto this socket). Takes no request body: unlike the TCP listener there is\nno bind address to choose, only the daemon-picked path under the\nworkspace. Idempotent: a repeat call returns the already-bound path and\ntoken unchanged, since a listener cannot be re-pointed once serving.",
        "operationId": "frontend_attach_target_vsock",
        "responses": {
          "200": {
            "description": "the UDS attach listener's socket path and per-instance token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FrontendAttachTargetVsockReport"
                }
              }
            }
          },
          "500": {
            "description": "failed to bind the attach listener",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "503": {
            "description": "the namespace is not ready yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts": {
      "get": {
        "operationId": "mounts_list",
        "responses": {
          "200": {
            "description": "loaded provider mounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MountInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts/{name}": {
      "get": {
        "operationId": "mount_inspect",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "the mount",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountInfo"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/providers": {
      "get": {
        "operationId": "providers_list",
        "responses": {
          "200": {
            "description": "installed provider catalog",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProviderSummary"
                  }
                }
              }
            }
          },
          "500": {
            "description": "provider catalog unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ready": {
      "get": {
        "operationId": "ready",
        "responses": {
          "200": {
            "description": "namespace listeners are serving",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyInfo"
                }
              }
            }
          },
          "503": {
            "description": "namespace listeners are not serving yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/shutdown": {
      "post": {
        "summary": "`POST /v1/shutdown`: release the daemon's serving latch and exit. Frontend\nprocesses have independent lifetimes and are torn down by the CLI.",
        "operationId": "shutdown",
        "responses": {
          "200": {
            "description": "daemon state at shutdown",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StopReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/status": {
      "get": {
        "operationId": "status",
        "responses": {
          "200": {
            "description": "daemon runtime facts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DaemonStatus"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "detail": {},
          "message": {
            "type": "string"
          }
        }
      },
      "CredentialHealth": {
        "type": "string",
        "enum": [
          "ready",
          "expiring_soon",
          "expired",
          "refresh_failed",
          "needs_consent",
          "missing",
          "static_unvalidated"
        ]
      },
      "CredentialStatus": {
        "type": "object",
        "required": [
          "id",
          "health",
          "scopes"
        ],
        "properties": {
          "expires_at": {
            "type": [
              "string",
              "null"
            ],
            "description": "RFC3339 expiry timestamp, when the credential carries one."
          },
          "health": {
            "$ref": "#/components/schemas/CredentialHealth"
          },
          "id": {
            "type": "string",
            "description": "Credential storage key, e.g. `github:oauth:default`."
          },
          "refresh_failed_attempts": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DaemonBackend": {
        "oneOf": [
          {
            "type": "object",
            "description": "Daemon spawned as a host-native child process.",
            "required": [
              "pid",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "native"
                ]
              },
              "pid": {
                "type": "integer",
                "format": "int32",
                "minimum": 0
              }
            }
          }
        ],
        "description": "Backend serving a daemon. The daemon always runs host-native; the CLI reads\nthis (and the runtime record) rather than assuming it."
      },
      "DaemonHealth": {
        "type": "object",
        "required": [
          "subsystems"
        ],
        "properties": {
          "subsystems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubsystemHealth"
            }
          }
        }
      },
      "DaemonStatus": {
        "type": "object",
        "description": "`GET /v1/status`: the daemon's runtime facts, loaded mounts, and non-secret\noperational health. Credentials are represented only by coarse health.",
        "required": [
          "version",
          "config_dir",
          "cache_dir",
          "providers_dir",
          "mounts"
        ],
        "properties": {
          "api_major": {
            "type": "integer",
            "format": "int32",
            "description": "Control API major version. Incompatible change when this differs.",
            "minimum": 0
          },
          "api_minor": {
            "type": "integer",
            "format": "int32",
            "description": "Control API minor version. Additive change; CLI warns and proceeds.",
            "minimum": 0
          },
          "backend": {
            "$ref": "#/components/schemas/DaemonBackend",
            "description": "Backend serving this daemon, so the CLI tears down and reports the right\nbackend without inferring it from configuration. Missing identity is not\nreclaimable; teardown stops instead of guessing."
          },
          "cache_dir": {
            "type": "string"
          },
          "config_dir": {
            "type": "string"
          },
          "executable": {
            "type": "string"
          },
          "frontends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FrontendInfo"
            },
            "description": "Every filesystem frontend currently attached to the shared namespace."
          },
          "health": {
            "$ref": "#/components/schemas/DaemonHealth",
            "description": "Daemon-owned health for runtime subsystems. CLI status renders these\nentries instead of reconstructing daemon health from raw fields."
          },
          "instance_id": {
            "type": "string",
            "description": "Random 16-hex-character id generated per daemon start. The CLI asserts it\nagainst the runtime record it resolved from, so a record overwritten by a\nrestart mid-command is detected instead of silently trusted."
          },
          "mounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountInfo"
            },
            "description": "Provider mounts loaded in the registry."
          },
          "pid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "providers_dir": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "DaemonSubsystem": {
        "type": "string",
        "enum": [
          "control",
          "backend",
          "frontend",
          "mounts"
        ]
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "auth_required",
          "credential_not_found",
          "mount_not_found",
          "spec_invalid",
          "daemon_shutting_down",
          "internal"
        ]
      },
      "FrontendAttachTargetReport": {
        "type": "object",
        "description": "`POST /v1/frontend/attach-target`: the TCP attach target a frontend dials\n(address plus per-instance attach token), whether just bound or already\nserving from an earlier call (or from `--attach-tcp` at daemon start).\nNamed after what it returns: the Omnifs VFS wire protocol client's\n`AttachTarget::Tcp`.",
        "required": [
          "addr",
          "token"
        ],
        "properties": {
          "addr": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "FrontendAttachTargetRequest": {
        "type": "object",
        "description": "Optional request body for `POST /v1/frontend/attach-target`. The address is\nhonored only on the first bind (the listener is idempotent thereafter).\nAn absent `bind_ip` selects loopback; native Linux may request the default\nDocker bridge gateway, which the daemon validates before binding.",
        "properties": {
          "bind_ip": {
            "type": [
              "string",
              "null"
            ]
          },
          "driver": {
            "$ref": "#/components/schemas/FrontendDelivery",
            "description": "The delivery mechanism attaching over this listener. Only `docker` is\naccepted today (krunkit attaches over vsock instead, through the\nseparate `/v1/frontend/attach-target/vsock` route); any other value is\na 400. Defaults to `docker` when omitted."
          }
        }
      },
      "FrontendAttachTargetVsockReport": {
        "type": "object",
        "description": "`POST /v1/frontend/attach-target/vsock`: the vsock attach target's host\nside, a token-checking UDS listener's socket path plus the per-instance\nattach token the guest presents (the Omnifs VFS wire protocol client's\n`AttachTarget::Vsock`).\nThis is the krunkit-on-macOS path: a guest VM has no shared host Unix\nsocket and no Docker-style loopback either, so it dials host vsock instead,\nand krunkit proxies every vsock connection onto `socket_path`. Every\nconnection krunkit forwards looks like the same trusted local peer to that\nsocket, so `token` (not filesystem permissions) is this listener's real\nauth, checked the same way the TCP listener's is. Takes no request body:\nunlike the TCP listener, there is no bind address to choose, only the\ndaemon-picked path under the workspace. Idempotent, same as\n[`FrontendAttachTargetReport`]: a repeat call returns the already-bound\npath and token unchanged.",
        "required": [
          "socket_path",
          "token"
        ],
        "properties": {
          "socket_path": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "FrontendDelivery": {
        "type": "string",
        "description": "How a frontend is delivered to the shared namespace. Assigned by the host\nat bind time per listener, never\nself-reported by the connecting guest.",
        "enum": [
          "local",
          "docker",
          "krunkit"
        ]
      },
      "FrontendInfo": {
        "type": "object",
        "required": [
          "source",
          "fs_type"
        ],
        "properties": {
          "delivery": {
            "$ref": "#/components/schemas/FrontendDelivery",
            "description": "How this frontend reaches the shared namespace. The host assigns this\nfrom which listener the connection arrived on, never from anything a\nconnecting guest claims about itself."
          },
          "fs_type": {
            "$ref": "#/components/schemas/FsType"
          },
          "mount_point": {
            "type": "string",
            "description": "The frontend-reported mount point. It is host-visible for the local\ndriver and display-only for Docker and krunkit guests."
          },
          "source": {
            "type": "string"
          }
        }
      },
      "FsType": {
        "type": "string",
        "enum": [
          "fuse",
          "nfs"
        ]
      },
      "HealthState": {
        "type": "string",
        "enum": [
          "starting",
          "healthy",
          "degraded",
          "unhealthy"
        ]
      },
      "MountInfo": {
        "type": "object",
        "required": [
          "mount",
          "provider_name",
          "provider_id"
        ],
        "properties": {
          "auth_health": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CredentialHealth"
              }
            ]
          },
          "mount": {
            "type": "string"
          },
          "provider_id": {
            "type": "string",
            "description": "Pinned provider content hash for the exact WASM artifact this mount runs."
          },
          "provider_name": {
            "type": "string",
            "description": "Provider NAME slug, e.g. `github`; credentials key on this value."
          }
        }
      },
      "ProviderArtifact": {
        "type": "object",
        "required": [
          "id_hash"
        ],
        "properties": {
          "id_hash": {
            "type": "string"
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ProviderSummary": {
        "type": "object",
        "required": [
          "name",
          "installed"
        ],
        "properties": {
          "installed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProviderArtifact"
            }
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ReadyInfo": {
        "type": "object",
        "description": "`GET /v1/ready`: 200 with `ready: true` once the immutable mount revision loads\nand every requested namespace listener is serving.\nNon-ready responses use [`ApiError`].",
        "required": [
          "ready"
        ],
        "properties": {
          "ready": {
            "type": "boolean"
          }
        }
      },
      "StopReport": {
        "type": "object",
        "description": "`POST /v1/shutdown`: daemon state immediately before exit.",
        "required": [
          "frontends",
          "providers_dropped"
        ],
        "properties": {
          "frontends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FrontendInfo"
            },
            "description": "Every attached frontend at the moment of shutdown."
          },
          "providers_dropped": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "SubsystemHealth": {
        "type": "object",
        "required": [
          "subsystem",
          "state",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/HealthState"
          },
          "subsystem": {
            "$ref": "#/components/schemas/DaemonSubsystem"
          }
        }
      }
    }
  }
}