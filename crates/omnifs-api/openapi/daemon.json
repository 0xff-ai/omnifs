{
  "openapi": "3.1.0",
  "info": {
    "title": "omnifs daemon control API",
    "description": "omnifs runtime daemon: provider registry and FUSE mount loop",
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "0.2.1"
  },
  "paths": {
    "/v1/events": {
      "get": {
        "summary": "Stream the inspector history snapshot followed by live records as\nnewline-framed JSON using the same wire format the raw TCP listener used to\nspeak, now chunk-encoded by HTTP. A lagged subscriber gets a\n`# dropped N events` comment line and resumes from the newest record.",
        "operationId": "events",
        "responses": {
          "200": {
            "description": "newline-framed inspector event stream",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "inspector stream disabled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts": {
      "get": {
        "operationId": "mounts_list",
        "responses": {
          "200": {
            "description": "loaded provider mounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MountInfo"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "mount_create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "mount create result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountReport"
                }
              }
            }
          },
          "400": {
            "description": "invalid mount spec",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts/{name}": {
      "get": {
        "operationId": "mount_inspect",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "the mount",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountInfo"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "mount_update",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MountUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "mount update result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountReport"
                }
              }
            }
          },
          "400": {
            "description": "invalid mount spec or approval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "mount_delete",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "mount delete result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountReport"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts/{name}/export": {
      "get": {
        "operationId": "mount_export",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "canonical-store snapshot tar",
            "content": {
              "application/x-tar": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "snapshot export failed",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ready": {
      "get": {
        "operationId": "ready",
        "responses": {
          "200": {
            "description": "filesystem frontend is serving",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyInfo"
                }
              }
            }
          },
          "503": {
            "description": "filesystem frontend is not serving yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reconcile": {
      "post": {
        "summary": "`POST /v1/reconcile`: converge the running mount set to `mounts/*.json`.",
        "operationId": "reconcile",
        "responses": {
          "200": {
            "description": "what the reconcile changed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReconcileReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/shutdown": {
      "post": {
        "summary": "`POST /v1/shutdown`: unmount the frontend and exit. The daemon holds the\nfrontend handle, so it tears itself down; `omnifs down` no longer infers the\nteardown from configuration.",
        "operationId": "shutdown",
        "responses": {
          "200": {
            "description": "what the daemon tore down before exiting",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StopReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/status": {
      "get": {
        "operationId": "status",
        "responses": {
          "200": {
            "description": "daemon runtime facts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DaemonStatus"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddedField": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "default": {},
          "name": {
            "type": "string"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "detail": {},
          "message": {
            "type": "string"
          }
        }
      },
      "AuthDelta": {
        "type": "object",
        "properties": {
          "new": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/AuthSurface"
              }
            ]
          },
          "old": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/AuthSurface"
              }
            ]
          }
        }
      },
      "AuthSchemeSurface": {
        "type": "object",
        "required": [
          "key",
          "scheme"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "scheme": {}
        }
      },
      "AuthSurface": {
        "type": "object",
        "required": [
          "default",
          "schemes"
        ],
        "properties": {
          "default": {
            "type": "string"
          },
          "schemes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthSchemeSurface"
            }
          }
        }
      },
      "CapabilityChange": {
        "type": "object",
        "required": [
          "kind",
          "value",
          "direction"
        ],
        "properties": {
          "direction": {
            "$ref": "#/components/schemas/CapabilityDirection"
          },
          "kind": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "CapabilityDirection": {
        "type": "string",
        "enum": [
          "added",
          "removed"
        ]
      },
      "DaemonBackend": {
        "type": "string",
        "description": "Backend serving a daemon. The CLI reads this (and the launch record) instead\nof inferring the backend from `[system].runtime`.",
        "enum": [
          "native",
          "docker"
        ]
      },
      "DaemonHealth": {
        "type": "object",
        "required": [
          "subsystems"
        ],
        "properties": {
          "subsystems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubsystemHealth"
            }
          }
        }
      },
      "DaemonStatus": {
        "type": "object",
        "description": "`GET /v1/status`: the daemon's runtime facts. Host-side state (mount\nconfigs, credential readiness) is the CLI's contribution to the merged\nstatus view; it never comes from the daemon.",
        "required": [
          "version",
          "mount_point",
          "config_dir",
          "cache_dir",
          "providers_dir",
          "mounts"
        ],
        "properties": {
          "api_major": {
            "type": "integer",
            "format": "int32",
            "description": "Control API major version. Incompatible change when this differs.",
            "minimum": 0
          },
          "api_minor": {
            "type": "integer",
            "format": "int32",
            "description": "Control API minor version. Additive change; CLI warns and proceeds.",
            "minimum": 0
          },
          "backend": {
            "$ref": "#/components/schemas/DaemonBackend",
            "description": "Backend serving this daemon, so the CLI tears down and reports the right\nbackend without inferring it from configuration. A daemon old enough to\nomit the field predates host-native and is read as Docker."
          },
          "cache_dir": {
            "type": "string"
          },
          "config_dir": {
            "type": "string"
          },
          "executable": {
            "type": "string"
          },
          "failed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountFailure"
            },
            "description": "Mounts that did not converge at the last reconcile, with reasons. Empty\nwhen every desired mount is serving; a dark mount appears here, not as a\nsilent absence from `mounts`."
          },
          "frontend": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FrontendInfo",
                "description": "The serving filesystem frontend (FUSE today; the protocol stays\nfrontend-agnostic for future NFSv4/FSKit modes), when one is up."
              }
            ]
          },
          "health": {
            "$ref": "#/components/schemas/DaemonHealth",
            "description": "Daemon-owned health for runtime subsystems. CLI status renders these\nentries instead of reconstructing daemon health from raw fields."
          },
          "mount_point": {
            "type": "string"
          },
          "mounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountInfo"
            },
            "description": "Provider mounts loaded in the registry."
          },
          "pid": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "providers_dir": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "DaemonSubsystem": {
        "type": "string",
        "enum": [
          "control",
          "backend",
          "frontend",
          "mounts"
        ]
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "auth_required",
          "consent_required",
          "mount_not_found",
          "spec_invalid",
          "provider_missing",
          "reconcile_busy",
          "daemon_shutting_down",
          "internal"
        ]
      },
      "FieldChange": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "name",
              "required",
              "kind"
            ],
            "properties": {
              "default": {},
              "kind": {
                "type": "string",
                "enum": [
                  "added"
                ]
              },
              "name": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "removed"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "became_required"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "became_optional"
                ]
              },
              "name": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "name",
              "old",
              "new",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "type_changed"
                ]
              },
              "name": {
                "type": "string"
              },
              "new": {},
              "old": {}
            }
          }
        ]
      },
      "FrontendInfo": {
        "type": "object",
        "required": [
          "source",
          "fs_type"
        ],
        "properties": {
          "fs_type": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "HealthState": {
        "type": "string",
        "enum": [
          "starting",
          "healthy",
          "degraded",
          "unhealthy"
        ]
      },
      "LimitChange": {
        "type": "object",
        "required": [
          "name",
          "value",
          "direction"
        ],
        "properties": {
          "direction": {
            "$ref": "#/components/schemas/LimitDirection"
          },
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "LimitDirection": {
        "type": "string",
        "enum": [
          "added",
          "removed"
        ]
      },
      "MountFailure": {
        "type": "object",
        "description": "One mount that did not converge during a reconcile. `mount` is the mount\nname, or the spec path when the name could not be parsed.",
        "required": [
          "mount",
          "kind",
          "reason"
        ],
        "properties": {
          "detail": {},
          "kind": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "mount": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "MountInfo": {
        "type": "object",
        "required": [
          "mount",
          "provider_id",
          "root_mount"
        ],
        "properties": {
          "mount": {
            "type": "string"
          },
          "provider_id": {
            "type": "string",
            "description": "Provider NAME slug. Field name kept as `provider_id` for wire stability; rename deferred to an `API_MAJOR` bump."
          },
          "root_mount": {
            "type": "boolean"
          }
        }
      },
      "MountOutcome": {
        "type": "string",
        "enum": [
          "added",
          "updated",
          "removed",
          "unchanged",
          "failed"
        ]
      },
      "MountReport": {
        "type": "object",
        "required": [
          "mount",
          "outcome"
        ],
        "properties": {
          "approved": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/UpgradeDelta"
              }
            ]
          },
          "failure": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/MountFailure"
              }
            ]
          },
          "mount": {
            "type": "string"
          },
          "outcome": {
            "$ref": "#/components/schemas/MountOutcome"
          }
        }
      },
      "MountUpdateRequest": {
        "type": "object",
        "required": [
          "spec"
        ],
        "properties": {
          "approved": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/UpgradeDelta"
              }
            ]
          },
          "spec": {}
        }
      },
      "ReadyInfo": {
        "type": "object",
        "description": "`GET /v1/ready`: 200 with `ready: true` once the filesystem is serving.\nNon-ready responses use [`ApiError`].",
        "required": [
          "ready"
        ],
        "properties": {
          "ready": {
            "type": "boolean"
          }
        }
      },
      "ReconcileReport": {
        "type": "object",
        "description": "`POST /v1/reconcile`: what converging the running mount set to the on-disk\ndesired state changed.",
        "required": [
          "added",
          "removed",
          "updated",
          "failed"
        ],
        "properties": {
          "added": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountFailure"
            }
          },
          "removed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updated": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "StopReport": {
        "type": "object",
        "description": "`POST /v1/shutdown`: what the daemon tore down before exiting.",
        "required": [
          "mount_point",
          "providers_dropped"
        ],
        "properties": {
          "frontend": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FrontendInfo"
              }
            ]
          },
          "mount_point": {
            "type": "string"
          },
          "providers_dropped": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "SubsystemHealth": {
        "type": "object",
        "required": [
          "subsystem",
          "state",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/HealthState"
          },
          "subsystem": {
            "$ref": "#/components/schemas/DaemonSubsystem"
          }
        }
      },
      "UpgradeDelta": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "identical"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "added",
              "kind"
            ],
            "properties": {
              "added": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AddedField"
                }
              },
              "kind": {
                "type": "string",
                "enum": [
                  "additive_config"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "changes",
              "kind"
            ],
            "properties": {
              "changes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/FieldChange"
                }
              },
              "kind": {
                "type": "string",
                "enum": [
                  "breaking_config"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "capabilities",
              "limits",
              "kind"
            ],
            "properties": {
              "auth": {
                "oneOf": [
                  {
                    "type": "null"
                  },
                  {
                    "$ref": "#/components/schemas/AuthDelta"
                  }
                ]
              },
              "capabilities": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CapabilityChange"
                }
              },
              "kind": {
                "type": "string",
                "enum": [
                  "capability_limit_or_auth"
                ]
              },
              "limits": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/LimitChange"
                }
              }
            }
          }
        ],
        "description": "Wire representation of a reviewed provider-upgrade delta.\n\nThe control API keeps this as transport data, not as a credential-bearing\nmount spec. The daemon converts it back into the workspace upgrade model and\nchecks that it covers the actual diff computed at the hot-swap boundary."
      }
    }
  }
}