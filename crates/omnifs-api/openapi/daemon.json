{
  "openapi": "3.1.0",
  "info": {
    "title": "omnifs daemon control API",
    "description": "omnifs runtime daemon: provider registry and FUSE mount loop",
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "0.2.1"
  },
  "paths": {
    "/v1/events": {
      "get": {
        "tags": [],
        "summary": "Stream the inspector history snapshot followed by live records as\nnewline-framed JSON using the same wire format the raw TCP listener used to\nspeak, now chunk-encoded by HTTP. A lagged subscriber gets a\n`# dropped N events` comment line and resumes from the newest record.",
        "operationId": "events",
        "responses": {
          "200": {
            "description": "newline-framed inspector event stream",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "inspector stream disabled",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts": {
      "get": {
        "tags": [],
        "operationId": "mounts_list",
        "responses": {
          "200": {
            "description": "loaded provider mounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MountInfo"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/mounts/{name}": {
      "get": {
        "tags": [],
        "operationId": "mount_inspect",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "mount name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "the mount",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MountInfo"
                }
              }
            }
          },
          "404": {
            "description": "mount not found",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ready": {
      "get": {
        "tags": [],
        "operationId": "ready",
        "responses": {
          "200": {
            "description": "filesystem frontend is serving",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyInfo"
                }
              }
            }
          },
          "503": {
            "description": "filesystem frontend is not serving yet",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadyInfo"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reconcile": {
      "post": {
        "tags": [],
        "summary": "`POST /v1/reconcile`: converge the running mount set to `mounts/*.json`.",
        "operationId": "reconcile",
        "responses": {
          "200": {
            "description": "what the reconcile changed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReconcileReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/shutdown": {
      "post": {
        "tags": [],
        "summary": "`POST /v1/shutdown`: unmount the frontend and exit. The daemon holds the\nfrontend handle, so it tears itself down; `omnifs down` no longer infers the\nteardown from configuration.",
        "operationId": "shutdown",
        "responses": {
          "200": {
            "description": "what the daemon tore down before exiting",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StopReport"
                }
              }
            }
          }
        }
      }
    },
    "/v1/status": {
      "get": {
        "tags": [],
        "operationId": "status",
        "responses": {
          "200": {
            "description": "daemon runtime facts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DaemonStatus"
                }
              }
            }
          }
        }
      }
    },
    "/v1/version": {
      "get": {
        "tags": [],
        "operationId": "version",
        "responses": {
          "200": {
            "description": "daemon control API version",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionInfo"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DaemonStatus": {
        "type": "object",
        "description": "`GET /v1/status`: the daemon's runtime facts. Host-side state (mount\nconfigs, credential readiness) is the CLI's contribution to the merged\nstatus view; it never comes from the daemon.",
        "required": [
          "version",
          "mount_point",
          "config_dir",
          "cache_dir",
          "providers_dir",
          "mounts"
        ],
        "properties": {
          "cache_dir": {
            "type": "string"
          },
          "config_dir": {
            "type": "string"
          },
          "frontend": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FrontendInfo",
                "description": "The serving filesystem frontend (FUSE today; the protocol stays\nfrontend-agnostic for future NFSv4/FSKit modes), when one is up."
              }
            ]
          },
          "mount_point": {
            "type": "string"
          },
          "mounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountInfo"
            },
            "description": "Provider mounts loaded in the registry."
          },
          "providers_dir": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "FrontendInfo": {
        "type": "object",
        "required": [
          "source",
          "fs_type"
        ],
        "properties": {
          "fs_type": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      },
      "MountFailure": {
        "type": "object",
        "description": "One mount that did not converge during a reconcile. `mount` is the mount\nname, or the spec path when the name could not be parsed.",
        "required": [
          "mount",
          "reason"
        ],
        "properties": {
          "mount": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "MountInfo": {
        "type": "object",
        "required": [
          "mount",
          "provider_id",
          "root_mount"
        ],
        "properties": {
          "mount": {
            "type": "string"
          },
          "provider_id": {
            "type": "string"
          },
          "root_mount": {
            "type": "boolean"
          }
        }
      },
      "ReadyInfo": {
        "type": "object",
        "description": "`GET /v1/ready`: 200 with `ready: true` once the filesystem is\nserving; 503 with `ready: false` while starting up.",
        "required": [
          "ready"
        ],
        "properties": {
          "ready": {
            "type": "boolean"
          }
        }
      },
      "ReconcileReport": {
        "type": "object",
        "description": "`POST /v1/reconcile`: what converging the running mount set to the on-disk\ndesired state changed.",
        "required": [
          "added",
          "removed",
          "updated",
          "failed"
        ],
        "properties": {
          "added": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failed": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MountFailure"
            }
          },
          "removed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "updated": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "StopReport": {
        "type": "object",
        "description": "`POST /v1/shutdown`: what the daemon tore down before exiting.",
        "required": [
          "mount_point",
          "providers_dropped"
        ],
        "properties": {
          "frontend": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FrontendInfo"
              }
            ]
          },
          "mount_point": {
            "type": "string"
          },
          "providers_dropped": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "VersionInfo": {
        "type": "object",
        "description": "`GET /v1/version`",
        "required": [
          "version",
          "api_version"
        ],
        "properties": {
          "api_version": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "version": {
            "type": "string"
          }
        }
      }
    }
  }
}