{
  "plugin": "omnifs_provider_github.wasm",
  "mount": "github",
  "auth": {
    "type": "bearer-token",
    "token_env": "GITHUB_TOKEN",
    "token_file": "/run/secrets/github_token"
  },
  "capabilities": {
    "domains": ["api.github.com"],
    "git_repos": ["git@github.com:*"],
    "max_memory_mb": 256
  }
}
