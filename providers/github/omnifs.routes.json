{
  "routes": [
    {
      "template": "/{owner}",
      "kind": "dir",
      "description": "A GitHub user or organization; lists their repositories"
    },
    {
      "template": "/{owner}/{repo}",
      "kind": "object",
      "description": "A GitHub repository",
      "representations": [
        "repo.json"
      ]
    },
    {
      "template": "/{owner}/{repo}/issues",
      "kind": "dir",
      "description": "Issue filters (open, all) for the repository"
    },
    {
      "template": "/{owner}/{repo}/issues/{filter}",
      "kind": "dir"
    },
    {
      "template": "/{owner}/{repo}/issues/{filter}/{number}",
      "kind": "object",
      "description": "A GitHub issue",
      "representations": [
        "item.md",
        "item.json"
      ],
      "children": [
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/title",
          "kind": "file",
          "description": "The issue title"
        },
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/body",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/state",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/user",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/comments",
          "kind": "dir",
          "description": "Issue comments, one file per comment"
        },
        {
          "template": "/{owner}/{repo}/issues/{filter}/{number}/comments/{idx}",
          "kind": "file"
        }
      ]
    },
    {
      "template": "/{owner}/{repo}/pulls",
      "kind": "dir"
    },
    {
      "template": "/{owner}/{repo}/pulls/{filter}",
      "kind": "dir"
    },
    {
      "template": "/{owner}/{repo}/pulls/{filter}/{number}",
      "kind": "object",
      "representations": [
        "item.md",
        "item.json"
      ],
      "children": [
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/title",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/body",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/state",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/user",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/comments",
          "kind": "dir"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/comments/{idx}",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/pulls/{filter}/{number}/diff",
          "kind": "file"
        }
      ]
    },
    {
      "template": "/{owner}/{repo}/repo",
      "kind": "tree_ref",
      "description": "The repository's working tree, served as a cloned subtree"
    },
    {
      "template": "/{owner}/{repo}/actions/runs",
      "kind": "dir"
    },
    {
      "template": "/{owner}/{repo}/actions/runs/{run_id}",
      "kind": "object",
      "representations": [
        "run.json"
      ],
      "children": [
        {
          "template": "/{owner}/{repo}/actions/runs/{run_id}/status",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/actions/runs/{run_id}/conclusion",
          "kind": "file"
        },
        {
          "template": "/{owner}/{repo}/actions/runs/{run_id}/log",
          "kind": "file"
        }
      ]
    }
  ]
}
