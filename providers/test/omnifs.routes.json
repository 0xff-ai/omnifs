{
  "routes": [
    {
      "template": "/items",
      "kind": "dir",
      "description": "Synthetic item collection, grouped by state filter"
    },
    {
      "template": "/items/{filter}",
      "kind": "dir"
    },
    {
      "template": "/items/{filter}/{number}",
      "kind": "object",
      "description": "A single synthetic item, identity-collapsed across filters",
      "representations": [
        "item.md",
        "item.json"
      ],
      "children": [
        {
          "template": "/items/{filter}/{number}/title",
          "kind": "file",
          "description": "The item's title, as plain text"
        },
        {
          "template": "/items/{filter}/{number}/state",
          "kind": "file"
        },
        {
          "template": "/items/{filter}/{number}/body",
          "kind": "file"
        },
        {
          "template": "/items/{filter}/{number}/comments",
          "kind": "dir",
          "description": "The item's comments, one file per comment index"
        },
        {
          "template": "/items/{filter}/{number}/comments/{idx}",
          "kind": "file"
        }
      ]
    },
    {
      "template": "/hello",
      "kind": "dir"
    },
    {
      "template": "/hello/message",
      "kind": "file"
    },
    {
      "template": "/hello/greeting",
      "kind": "file"
    },
    {
      "template": "/hello/projected",
      "kind": "file"
    },
    {
      "template": "/hello/lazy",
      "kind": "file"
    },
    {
      "template": "/hello/fresh-full",
      "kind": "file"
    },
    {
      "template": "/hello/ranged",
      "kind": "file"
    },
    {
      "template": "/hello/unknown-ranged",
      "kind": "file"
    },
    {
      "template": "/hello/large-ranged",
      "kind": "file"
    },
    {
      "template": "/hello/volatile-tail",
      "kind": "file"
    },
    {
      "template": "/hello/bundle",
      "kind": "dir"
    },
    {
      "template": "/hello/feed",
      "kind": "dir"
    },
    {
      "template": "/hello/unbounded",
      "kind": "dir"
    },
    {
      "template": "/hello/throttled",
      "kind": "dir"
    },
    {
      "template": "/hello/snapshot",
      "kind": "dir"
    },
    {
      "template": "/hello/snapshot/comments",
      "kind": "dir"
    },
    {
      "template": "/scoped",
      "kind": "dir"
    },
    {
      "template": "/scoped/item",
      "kind": "file"
    },
    {
      "template": "/dynamic/{name}",
      "kind": "dir"
    },
    {
      "template": "/checkout",
      "kind": "tree_ref",
      "description": "Subtree handoff: the host takes over the whole checkout tree"
    }
  ]
}
