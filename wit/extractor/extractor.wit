/// Archive extraction sandbox interface.
///
/// The host preopens the source archive's parent directory as `/blob/`
/// (with the archive at `/blob/blob.dat`, read-only) and the
/// destination directory as `/out/` (read-write). The component walks
/// the archive and writes entries under `/out/`, enforcing the limits
/// in `extract-options`. Trips return a typed `extract-error`; success
/// returns `extract-stats`.
package omnifs:archive-extractor@0.1.0;

interface extract {
    enum archive-format {
        tar-gz,
        tar,
        zip,
    }

    record extract-options {
        format: archive-format,
        strip-prefix: option<string>,
        max-entries: u64,
        max-file-size: u64,
        max-total-bytes: u64,
        max-path-depth: u32,
        max-path-len: u32,
    }

    record extract-stats {
        entries: u64,
        bytes-written: u64,
    }

    variant extract-error {
        too-many-entries,
        file-too-large(string),
        total-too-large,
        path-too-deep(string),
        path-too-long(string),
        unsafe-path(string),
        unsupported-entry-kind(string),
        malformed(string),
        io(string),
    }

    extract: func(options: extract-options) -> result<extract-stats, extract-error>;
}

world extractor {
    export extract;
}
