package omnifs:provider@0.2.0;

// === Shared types ===

interface types {
    type correlation-id = u64;
    type stream-id = u64;
    type repo-id = u64;
    type tree-ref = u64;
    type file-handle = u64;
    type blob-id = u64;

    // --- Callouts (provider -> host, request/response) ---

    /// Work the host runs on the provider's behalf. Every callout expects
    /// a matching `callout-result` back via `resume`; there are no
    /// fire-and-forget callouts.
    variant callout {
        fetch(http-request),
        stream-open(http-request),
        stream-recv(stream-id),
        stream-close(stream-id),
        ws-connect(ws-connect-request),
        ws-send(ws-send-request),
        ws-recv(ws-recv-request),
        ws-close(stream-id),
        git-open-repo(git-open-request),
        /// HTTP fetch whose response body lands in the host's disk-backed
        /// blob cache instead of crossing the WIT boundary. Returns a
        /// `blob-id` plus response metadata; the bytes can later be served
        /// verbatim as file content (`file-content-result.blob`) or
        /// mounted as a directory tree (`open-archive`).
        fetch-blob(blob-fetch-request),
        /// Mount a stored blob as a directory tree, with the host
        /// performing decompression and walk based on the requested
        /// archive format. Returns a `tree-ref` resolved by the host's
        /// existing tree-serving path (the same one git-open-repo uses).
        open-archive(archive-open-request),
        /// Bring a (range of a) stored blob across the WIT boundary so
        /// the provider can parse it. Use sparingly; the point of blobs
        /// is to keep large bytes host-side.
        read-blob(read-blob-request),
    }

    /// Unified provider return value. A handler may return:
    ///
    /// - `terminal = some(...), callouts = []` — pure terminal.
    /// - `terminal = none, callouts = [..]` — suspension: host runs the
    ///   callouts and calls `resume(id, results)`.
    /// - `terminal = some(...), callouts = [..]` — terminal with trailing
    ///   callouts (rare; host executes them, discards results, returns the
    ///   terminal).
    /// - Both empty is a protocol error.
    record provider-return {
        callouts: list<callout>,
        terminal: option<op-result>,
    }

    /// Top-level terminal. Every non-`err` variant is 1:1 with a handler
    /// operation; the arm name matches the operation, not the payload
    /// shape.
    variant op-result {
        lookup(lookup-result),
        %list(list-result),
        read(file-content-result),
        init(provider-info),
        event(event-outcome),
        err(provider-error),
        plan-mutations(list<planned-mutation>),
        execute(mutation-outcome),
        fetch-resource(list<file-entry>),
    }

    // --- Callout results (host -> provider, non-recursive) ---

    variant callout-result {
        http-response(http-response),
        stream-opened(stream-id),
        stream-chunk(option<list<u8>>),
        stream-closed,
        ws-connected(stream-id),
        ws-message(option<list<u8>>),
        ws-closed,
        git-repo-opened(git-repo-info),
        blob-fetched(blob-fetched),
        archive-opened(archive-opened),
        blob-read(list<u8>),
        callout-error(callout-error),
    }

    record callout-error {
        kind: error-kind,
        message: string,
        retryable: bool,
    }

    enum error-kind {
        not-found,
        not-a-directory,
        not-a-file,
        permission-denied,
        invalid-input,
        too-large,
        network,
        timeout,
        denied,
        rate-limited,
        version-mismatch,
        internal,
    }

    type callout-results = list<callout-result>;

    record provider-error {
        kind: error-kind,
        message: string,
        retryable: bool,
    }

    // --- Terminal payloads ---

    /// Lookup terminal. `subtree(tree-ref)` lets `lookup-child` return a
    /// subtree handoff directly. `not-found` is bare by design; it carries
    /// no siblings or sibling-files.
    variant lookup-result {
        entry(lookup-entry),
        subtree(tree-ref),
        not-found,
    }

    /// The non-subtree, non-miss shape of a lookup: the found entry plus
    /// cache-adjacent data. `target` is non-optional because the miss
    /// case is the `not-found` arm of `lookup-result`, not a null target.
    record lookup-entry {
        target: dir-entry,
        siblings: list<dir-entry>,
        sibling-files: list<projected-file>,

        /// Whether the siblings list is exhaustive.
        ///
        /// When true, the host treats absence from `siblings` as
        /// authoritative negative: any lookup for a name not listed
        /// returns ENOENT without another provider call. Set false
        /// when siblings come from a paginated or capped source that
        /// may omit valid children.
        exhaustive: bool,

        /// Content the provider already has in hand for named paths
        /// nested under the looked-up entry. Equivalent to
        /// `dir-listing.preload` and applied at the same boundary:
        /// when a directory lookup hits a dir handler that staged
        /// preloads for its children, those preloads flow out with
        /// the lookup terminal rather than being dropped.
        preload: list<preload-item>,
    }

    /// List terminal. `subtree(tree-ref)` lets `list-children` return a
    /// subtree handoff directly.
    variant list-result {
        entries(dir-listing),
        subtree(tree-ref),
    }

    /// Event handler terminal. Carries invalidations the host must apply
    /// at the response boundary. Empty lists are valid (no-op terminal).
    record event-outcome {
        invalidate-paths: list<string>,
        invalidate-prefixes: list<string>,
    }

    /// Read terminal payload. Inline content travels in the WIT; blob
    /// content stays in the host's blob cache and is streamed straight
    /// to FUSE without a round trip through the provider.
    variant file-content-result {
        inline(inline-file-content),
        blob(blob-file-content),
    }

    record inline-file-content {
        content: list<u8>,
        sibling-files: list<projected-file>,
    }

    record blob-file-content {
        blob: blob-id,
        sibling-files: list<projected-file>,
    }

    // --- Data types ---

    record http-request {
        method: string,
        url: string,
        headers: list<header>,
        body: option<list<u8>>,
    }

    record http-response {
        status: u16,
        headers: list<header>,
        body: list<u8>,
    }

    record header {
        name: string,
        value: string,
    }

    record ws-connect-request {
        url: string,
        headers: list<header>,
    }

    record ws-send-request {
        id: stream-id,
        data: list<u8>,
    }

    record ws-recv-request {
        id: stream-id,
    }

    record git-open-request {
        clone-url: string,
        cache-key: string,
    }

    /// Archive formats the host knows how to extract for `open-archive`.
    /// Closed enum on purpose; add arms when a provider needs them.
    enum archive-format {
        tar-gz,
        tar,
        zip,
    }

    /// HTTP fetch that lands its response body in the host's disk-backed
    /// blob cache. `cache-key` is provider-scoped: two providers may
    /// reuse the same key safely. Reusing the same `cache-key` from the
    /// same provider deduplicates the fetch — the host returns the
    /// existing `blob-id` without re-downloading.
    record blob-fetch-request {
        method: string,
        url: string,
        headers: list<header>,
        body: option<list<u8>>,
        cache-key: string,
    }

    /// Result of a successful `fetch-blob`. The body is on disk; only the
    /// metadata crosses the WIT.
    record blob-fetched {
        blob: blob-id,
        size: u64,
        content-type: option<string>,
        etag: option<string>,
        status: u16,
        response-headers: list<header>,
    }

    /// Mount a stored blob as a directory tree. `format` tells the host
    /// how to decompress and walk the bytes. `strip-prefix`, when set,
    /// is removed from every entry's path at mount time — useful for
    /// archives whose tarball wraps everything in a single top-level
    /// directory (e.g. crates.io's `serde-1.0.197/`).
    record archive-open-request {
        blob: blob-id,
        format: archive-format,
        strip-prefix: option<string>,
    }

    record archive-opened {
        tree: tree-ref,
    }

    /// Bring (a range of) a stored blob across the WIT. `len = none`
    /// reads to end of blob, capped by host policy. Mostly an escape
    /// hatch; prefer `open-archive` or blob-backed file content.
    record read-blob-request {
        blob: blob-id,
        offset: u64,
        len: option<u32>,
    }

    variant cursor {
        opaque(string),
        page(u32),
    }

    record git-repo-info {
        repo: repo-id,
        tree: tree-ref,
    }

    /// File content the provider hands to the host so that a later read
    /// of provider-relative `path` can be served without another provider
    /// round trip. Used to fan out adjacent data from an upstream payload
    /// the handler has already fetched.
    record preloaded-file {
        path: string,
        content: list<u8>,
    }

    /// Entry metadata the provider hands to the host so that a later
    /// lookup of provider-relative `path` can be served without another
    /// provider round trip.
    record preloaded-entry {
        path: string,
        kind: entry-kind,
        size: option<u64>,
    }

    variant preload-item {
        file(preloaded-file),
        entry(preloaded-entry),
    }

    record log-entry {
        level: log-level,
        message: string,
    }

    enum log-level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    /// A directory listing returned by a provider, pairing the child
    /// entries with a signal about how the host should interpret absence.
    ///
    /// The host caches listings to accelerate readdir and lookup. On a
    /// lookup for "does child X exist in directory D?", the host can
    /// answer ENOENT from a cached listing of D without a provider
    /// round-trip, but only when the listing is known to be exhaustive.
    /// This matters because FUSE clients (shells, editors, ripgrep)
    /// routinely stat names that cannot exist in a projected filesystem,
    /// and each miss would otherwise be a blocking call into the
    /// provider.
    record dir-listing {
        entries: list<dir-entry>,

        /// Whether every immediate child of this directory is present
        /// in `entries`.
        ///
        /// When true, absence from the entry list is a sound negative
        /// lookup: the host may return ENOENT for any name not listed
        /// without consulting the provider. This property applies only
        /// to immediate child names; it says nothing about metadata
        /// accuracy or recursive subtree completeness. Freshness is
        /// governed by explicit invalidation; cached listings do not
        /// expire on time.
        ///
        /// Set true when the set of children is structurally known
        /// (fixed schemas, confirmed empties). Set false when the
        /// listing comes from a paginated API, a capped query, or any
        /// source that may omit valid children. The host still caches
        /// non-exhaustive entries for readdir; it just will not use
        /// them to deny lookups.
        exhaustive: bool,

        /// Content or entry metadata the provider already has in hand
        /// for any path under this provider. The host caches these so a
        /// later lookup or read of each path is served without another
        /// provider round trip. Consumed at the response boundary; the
        /// cached listing carries an empty preload list.
        preload: list<preload-item>,
    }

    record dir-entry {
        name: string,
        kind: entry-kind,
        size: option<u64>,
        projected-files: option<list<projected-file>>,
    }

    record projected-file {
        name: string,
        content: list<u8>,
    }

    enum entry-kind {
        directory,
        file,
    }

    record file-entry {
        path: string,
        content: list<u8>,
        mode: u32,
        version-token: option<string>,
    }

    record file-change {
        path: string,
        kind: change-kind,
        old-content: option<list<u8>>,
        new-content: option<list<u8>>,
    }

    enum change-kind {
        added,
        modified,
        deleted,
    }

    record planned-mutation {
        id: string,
        description: string,
        depends-on: list<string>,
        version-token: option<string>,
        payload: list<u8>,
    }

    record mutation-outcome {
        post-actions: list<post-action>,
    }

    variant post-action {
        rename-path(rename-action),
        write-file(file-entry),
        delete-path(string),
        set-mode(mode-action),
    }

    record rename-action {
        source: string,
        dest: string,
    }

    record mode-action {
        path: string,
        mode: u32,
    }

    record provider-info {
        name: string,
        version: string,
        description: string,
    }

    record active-path-set {
        mount-id: string,
        mount-name: string,
        paths: list<string>,
    }

    record timer-tick-context {
        active-paths: list<active-path-set>,
    }

    record requested-capabilities {
        domains: list<string>,
        auth-types: list<string>,
        max-memory-mb: u32,
        needs-git: bool,
        needs-websocket: bool,
        needs-streaming: bool,
        refresh-interval-secs: u32,
    }

    variant provider-event {
        file-changed(string),
        webhook-received(list<u8>),
        timer-tick(timer-tick-context),
        auth-refreshed,
    }
}

// === Provider exports ===

interface lifecycle {
    use types.{provider-return, requested-capabilities};

    initialize: func(config: list<u8>) -> provider-return;
    shutdown: func();
    get-config-schema: func() -> option<string>;
    capabilities: func() -> requested-capabilities;
}

interface browse {
    use types.{provider-return, correlation-id};

    lookup-child: func(id: correlation-id, parent-path: string, name: string)
        -> provider-return;
    list-children: func(id: correlation-id, path: string)
        -> provider-return;
    read-file: func(id: correlation-id, path: string)
        -> provider-return;
    open-file: func(id: correlation-id, path: string)
        -> provider-return;
    read-chunk: func(id: correlation-id, handle: u64, offset: u64, len: u32)
        -> provider-return;
    close-file: func(handle: u64);
}

interface reconcile {
    use types.{provider-return, correlation-id, file-change, planned-mutation};

    plan-mutations: func(id: correlation-id, changes: list<file-change>)
        -> provider-return;
    execute: func(id: correlation-id, mutation: planned-mutation)
        -> provider-return;
    fetch-resource: func(id: correlation-id, resource-path: string)
        -> provider-return;
}

interface resume {
    use types.{provider-return, correlation-id, callout-results};

    resume: func(id: correlation-id, callout-outcome: callout-results)
        -> provider-return;
    cancel: func(id: correlation-id);
}

interface notify {
    use types.{provider-return, correlation-id, provider-event};

    on-event: func(id: correlation-id, event: provider-event)
        -> provider-return;
}

// === Host import ===

interface log {
    use types.{log-entry};

    log: func(entry: log-entry);
}

// === Worlds ===

world provider-core {
    import log;
    export lifecycle;
    export browse;
    export resume;
}

world provider {
    import log;
    export lifecycle;
    export browse;
    export resume;
    export reconcile;
    export notify;
}
